{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "启动 Web 服务",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/moon-media",
      "args": ["serve"],
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "运行测试",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "pytest", "tests/", "-q"],
      "problemMatcher": []
    }
  ]
}
