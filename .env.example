# Keep all model/cache/runtime files inside this project.
export MOON_MEDIA_LAB_HOME="$(pwd)"
export MOON_MEDIA_LAB_MODELS_DIR="$MOON_MEDIA_LAB_HOME/models"
export MOON_MEDIA_LAB_CACHE_DIR="$MOON_MEDIA_LAB_HOME/cache"
export MOON_MEDIA_LAB_JOBS_DIR="$MOON_MEDIA_LAB_HOME/jobs"
export MOON_MEDIA_LAB_DOWNLOADS_DIR="$MOON_MEDIA_LAB_HOME/downloads"
export MOON_MEDIA_LAB_OUTPUT_DIR="$MOON_MEDIA_LAB_HOME/output"

# Keep common model libraries from writing to global ~/.cache by default.
export HF_HOME="$MOON_MEDIA_LAB_CACHE_DIR/huggingface"
export HUGGINGFACE_HUB_CACHE="$MOON_MEDIA_LAB_CACHE_DIR/huggingface/hub"
export TRANSFORMERS_CACHE="$MOON_MEDIA_LAB_CACHE_DIR/huggingface/transformers"
export TORCH_HOME="$MOON_MEDIA_LAB_CACHE_DIR/torch"
export XDG_CACHE_HOME="$MOON_MEDIA_LAB_CACHE_DIR/xdg"
export MODELSCOPE_CACHE="$MOON_MEDIA_LAB_CACHE_DIR/modelscope"

# Engine settings.
export MOON_MEDIA_LAB_DEFAULT_ASR_ENGINE="sensevoice"
export MOON_MEDIA_LAB_DEFAULT_TTS_ENGINE="mock"
# export MOON_MEDIA_LAB_DEVICE="cpu"
# export MOON_MEDIA_LAB_SENSEVOICE_MODEL_DIR=""
# export MOON_MEDIA_LAB_FFMPEG="/path/to/ffmpeg"
